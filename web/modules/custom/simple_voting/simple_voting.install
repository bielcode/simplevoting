/**
 * Implements hook_install().
 */
function simple_voting_install(): void {
  /** @var \Drupal\user\RoleInterface|null $role */
  $role = \Drupal::entityTypeManager()
    ->getStorage('user_role')
    ->load('authenticated');

  if ($role === NULL) {
    return;
  }

  $role->grantPermission('vote in polls');
  $role->save();
}

/**
 * Implements hook_uninstall().
 */
function simple_voting_uninstall(): void {

}

/**
 * Corrige question_id de INT para VARCHAR(128) nas tabelas option e vote.
 */
function simple_voting_update_10001(): void {
  $schema = \Drupal::database()->schema();

  $spec = [
    'description' => 'Machine name da VotingQuestion (ConfigEntity ID).',
    'type'        => 'varchar',
    'length'      => 128,
    'not null'    => TRUE,
    'default'     => '',
  ];

  $schema->changeField('simple_voting_option', 'question_id', 'question_id', $spec);
  $schema->changeField('simple_voting_vote',   'question_id', 'question_id', $spec);
}
